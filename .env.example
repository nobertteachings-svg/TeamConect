# App URL (SEO, sitemap, emails, OG)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Database (Prisma). On Vercel/serverless use a pooled URL (Neon pooler, Supabase pooler, PgBouncer)
# and consider ?connection_limit=5 to avoid exhausting connections.
#
# Vercel / CI: `npm run build` only runs `prisma generate` + `next build` (no DB at build time).
# Apply migrations to production yourself: DATABASE_URL="your-production-url" npx prisma migrate deploy
# Local full build with migrate: npm run build:with-migrate
DATABASE_URL="postgresql://user:password@localhost:5432/teamconect?schema=public"

# NextAuth — NEXTAUTH_SECRET ≥ 32 chars (enforced at startup).
# NEXTAUTH_URL must be the exact public origin users see (https, no trailing slash), e.g.:
#   https://team-conect.vercel.app   OR   https://teamconect.com
# If it does not match the URL in the browser, Google/GitHub OAuth will fail or mis-route cookies.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# OAuth — leave blank to disable that provider
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
#
# ── Google Cloud Console (fix redirect_uri_mismatch) ───────────────────────────
# APIs & Services → Credentials → OAuth 2.0 Client ID (type: Web application)
#
# Authorized JavaScript origins — add every host you use:
#   https://team-conect.vercel.app
#   https://teamconect.com
#   https://www.teamconect.com    (if you use www)
#   http://localhost:3000
#
# Authorized redirect URIs — one line per host; must match NEXTAUTH_URL + this path:
#   https://team-conect.vercel.app/api/auth/callback/google
#   https://teamconect.com/api/auth/callback/google
#   https://www.teamconect.com/api/auth/callback/google   (only if NEXTAUTH_URL uses www)
#   http://localhost:3000/api/auth/callback/google
#
# ── GitHub OAuth App ──────────────────────────────────────────────────────────
# Settings → Developer settings → OAuth Apps → Authorization callback URL:
#   {NEXTAUTH_URL}/api/auth/callback/github
# Example: https://team-conect.vercel.app/api/auth/callback/github

# ── Email (sign-in OTP, waitlist, founder alerts) ─────────────────────────────
#
# Gmail SMTP only (typical for self-hosted / Vercel): set all of these on the host (e.g. Vercel → Settings → Environment Variables).
# 1) Google Account → Security → enable 2-Step Verification → App passwords → create "Mail" for this app.
# 2) Copy the 16-character password into GMAIL_APP_PASSWORD (spaces optional; we strip them).
# 3) GMAIL_USER = full Gmail address. EMAIL_FROM should match that mailbox (or a verified "Send mail as" alias).
# 4) Do not use your normal Gmail password — only an App Password works.
#
# On your host (e.g. Vercel), set these — and for Gmail-only, uncomment the two lines below so Resend is never used:
# EMAIL_TRANSPORT="smtp"
# EMAIL_SMTP_ONLY="1"
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
EMAIL_FROM=""
# Example production: EMAIL_FROM="TeamConect <you@gmail.com>"
#
# Local dev: leave GMAIL_* empty to log OTP in the terminal; or fill GMAIL_* to test real delivery.
#
# EMAIL_TRANSPORT: unset (auto), "smtp", or "resend". Auto uses SMTP when GMAIL_* or SMTP_* is set.
#
# Option B — Generic SMTP (e.g. Workspace, SendGrid SMTP relay)
# SMTP_URL="smtps://user:pass@smtp.example.com:465"
# Or: SMTP_HOST, SMTP_PORT (default 587), SMTP_USER, SMTP_PASS, SMTP_SECURE=1 for 465
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_SECURE="0"
#
# Option C — Resend (optional; needs verified domain for arbitrary recipients)
RESEND_API_KEY=""
EMAIL_REPLY_TO=""
#
# EMAIL_OTP_ENABLED: optional override (true/false/1/0). In production, if unset, OTP is hidden when mail is not configured.

# Redis (Upstash) — optional for list caching; without it, rate limits are in-memory per instance.
# Multi-instance production: set both URL and token, or set REQUIRE_UPSTASH_IN_PRODUCTION=1 to fail startup if Redis is missing.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
REQUIRE_UPSTASH_IN_PRODUCTION=""

# Sentry — optional. Server SDK also uses this if SENTRY_DSN is unset.
NEXT_PUBLIC_SENTRY_DSN=""

# PostHog — optional (NEXT_PUBLIC_POSTHOG_HOST defaults in code)
NEXT_PUBLIC_POSTHOG_KEY=""

# Integration tests only — PostgreSQL URL (can match DATABASE_URL or a dedicated test DB). See npm run test:integration.
# TEST_DATABASE_URL=""

# Readiness probe (no secret): GET /api/health — 200 if DB answers, 503 otherwise. Restrict at your edge if you do not want it public.
