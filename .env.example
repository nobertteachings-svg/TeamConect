# App URL (SEO, sitemap, emails, OG)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Database (Prisma). On Vercel/serverless use a pooled URL (Neon pooler, Supabase pooler, PgBouncer)
# and consider ?connection_limit=5 to avoid exhausting connections.
DATABASE_URL="postgresql://user:password@localhost:5432/teamconnect?schema=public"

# NextAuth — in production, NEXTAUTH_URL must match your public URL; NEXTAUTH_SECRET ≥ 32 chars (enforced at startup).
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# OAuth — leave blank to disable that provider
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Email — pick one transport (auto prefers SMTP if GMAIL_* / SMTP_* / SMTP_URL is set, else Resend).
# EMAIL_TRANSPORT: unset (auto), "smtp", or "resend"
#
# Option A — Gmail (no custom domain): Google Account → Security → 2-Step Verification → App passwords.
# Use the app password as GMAIL_APP_PASSWORD (not your normal password). Daily send limits apply.
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
#
# Option B — Generic SMTP (e.g. Workspace, SendGrid SMTP relay)
# SMTP_URL="smtps://user:pass@smtp.example.com:465"
# Or: SMTP_HOST, SMTP_PORT (default 587), SMTP_USER, SMTP_PASS, SMTP_SECURE=1 for 465
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_SECURE="0"
#
# Option C — Resend (needs verified domain for arbitrary recipients; onboarding@resend.dev is test-only)
RESEND_API_KEY=""
EMAIL_FROM="TeamConnect <onboarding@resend.dev>"
EMAIL_REPLY_TO=""
#
# EMAIL_OTP_ENABLED: optional override (true/false/1/0). If unset in production, email OTP is hidden when
# no SMTP is configured and (RESEND missing or EMAIL_FROM uses onboarding@resend.dev).

# Redis (Upstash) — optional for list caching; without it, rate limits are in-memory per instance.
# Multi-instance production: set both URL and token, or set REQUIRE_UPSTASH_IN_PRODUCTION=1 to fail startup if Redis is missing.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
REQUIRE_UPSTASH_IN_PRODUCTION=""

# Sentry — optional. Server SDK also uses this if SENTRY_DSN is unset.
NEXT_PUBLIC_SENTRY_DSN=""

# PostHog — optional (NEXT_PUBLIC_POSTHOG_HOST defaults in code)
NEXT_PUBLIC_POSTHOG_KEY=""

# Integration tests only — PostgreSQL URL (can match DATABASE_URL or a dedicated test DB). See npm run test:integration.
# TEST_DATABASE_URL=""

# Readiness probe (no secret): GET /api/health — 200 if DB answers, 503 otherwise. Restrict at your edge if you do not want it public.
